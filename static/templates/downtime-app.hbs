<div class="downtime-app-container">
	<header class="downtime-header">
		<div class="downtime-branding">
			<h1 class="branding-title">yugen-downtime</h1>
		</div>
		<nav class="sheet-tabs tabs" data-group="downtime">
			{{#each tabs}}
			<a class="item {{this.cssClass}}" data-action="tab" data-group="{{this.group}}" data-tab="{{this.id}}">
				<i class="{{this.icon}}"></i> {{this.label}}
			</a>
			{{/each}}
		</nav>
	</header>

	<section class="sheet-body">

		{{!-- ======================== ACTIONS TAB ======================== --}}
		{{#if tabs.actions.active}}
		<div class="tab actions-tab">
			{{#if player.has_actor}}
			<div class="player-hero">
				<div class="hero-left">
					<span class="hero-subtitle">downtime manager</span>
					<h2 class="hero-title">{{player.name}}</h2>
				</div>
				<div class="hero-points-card">
					<span class="points-val">{{player.points}}</span>
					<span class="points-lbl">Points</span>
				</div>
			</div>

			{{#if is_active}}
			<div class="actions-grid">
				{{#each actions}}
				<div class="action-card {{#unless this.can_afford}}disabled{{/unless}}">
					<div class="card-header-row">
						<h3 class="card-title">{{this.name}}</h3>
						<span class="card-cost">{{this.cost}} {{#if (eq this.cost 1)}}point{{else}}points{{/if}}</span>
					</div>
					<p class="card-desc">{{this.description}}</p>

					<div class="card-meta">
						{{#if this.roll_check}}
						<div class="meta-badge check-badge">
							<i class="fas fa-dice-d20"></i> {{this.roll_check}} {{#if this.dc}}(DC {{this.dc}}){{/if}}
						</div>
						{{/if}}
						{{#if this.macro_name}}
						<div class="meta-badge macro-badge">
							<i class="fas fa-terminal"></i> {{this.macro_name}}
						</div>
						{{/if}}
					</div>

					<button class="action-btn buy-btn" data-action="buy" data-action-id="{{this.id}}" data-actor-id="{{../player.id}}" {{#unless this.can_afford}}disabled{{/unless}}>
						Invest points
					</button>
				</div>
				{{/each}}
			</div>
			{{else}}
			<div class="empty-banner warning">
				<i class="fas fa-hourglass-half"></i>
				<div class="banner-text">
					<h4>Downtime is currently inactive</h4>
					<p>Wait for the Gamemaster to activate downtime mode to invest your points.</p>
				</div>
			</div>
			{{/if}}

			<div class="history-section">
				<div class="section-title-row">
					<h3 class="section-heading">My Activity</h3>
				</div>
				<div class="logs-feed">
					{{#each player_logs}}
					<div class="feed-item">
						<span class="item-time">{{this.formatted_time}}</span>
						<span class="item-text">
							Invested in <strong>{{this.action_name}}</strong> ({{this.cost}} {{#if (eq this.cost 1)}}point{{else}}points{{/if}})
							{{#if this.roll_check}}
							- Rolled <strong>{{this.roll_total}}</strong> {{#if this.dc}}vs DC {{this.dc}}{{/if}} ({{#if this.roll_success}}<span class="success-text">Success</span>{{else}}<span class="failure-text">Failure</span>{{/if}})
							{{/if}}
						</span>
					</div>
					{{else}}
					<div class="feed-empty">No investments recorded yet.</div>
					{{/each}}
				</div>
			</div>

			{{else}}
			<div class="empty-banner danger">
				<i class="fas fa-user-slash"></i>
				<div class="banner-text">
					<h4>No Active Character</h4>
					<p>Please select or assign a controlled character token to participate in downtime.</p>
				</div>
			</div>
			{{/if}}
		</div>
		{{/if}}

		{{!-- ======================== CRAFT TAB ======================== --}}
		{{#if tabs.craft.active}}
		<div class="tab actions-tab craft-browse-tab">
			{{#if player.has_actor}}
			<div class="player-hero">
				<div class="hero-left">
					<span class="hero-subtitle">crafting system</span>
					<h2 class="hero-title">{{player.name}}</h2>
				</div>
				<div class="hero-points-card">
					<span class="points-val">{{player.points}}</span>
					<span class="points-lbl">Points</span>
				</div>
			</div>

			{{#if craft_enabled}}
				{{#if recipes.length}}
				<div class="craft-recipes-grid">
					{{#each recipes}}
					<div class="craft-recipe-card {{#unless this.can_craft}}disabled{{/unless}}">
						<div class="card-header-row">
							<h3 class="card-title">{{this.name}}</h3>
							<span class="card-cost">{{this.dt_cost}} {{#if (eq this.dt_cost 1)}}point{{else}}points{{/if}}</span>
						</div>

						{{#if this.description}}
						<p class="card-desc">{{this.description}}</p>
						{{/if}}

						<div class="craft-card-body">
							<div class="craft-ingredients-section">
								<span class="craft-section-label">Requires</span>
								<div class="craft-ingredients-list">
									{{#each this.ingredients}}
									<div class="craft-ingredient-row {{#unless this.has_enough}}missing{{/unless}}">
										<img class="craft-ing-img" src="{{this.img}}" alt="{{this.name}}">
										<span class="craft-ing-name">{{this.name}}</span>
										<span class="craft-ing-qty">{{this.available}}/{{this.quantity}}</span>
									</div>
									{{else}}
									<span class="craft-no-ingredients">No ingredients required.</span>
									{{/each}}
								</div>
							</div>

							<div class="craft-arrow-col">
								<i class="fas fa-arrow-right craft-arrow"></i>
							</div>

							<div class="craft-output-section">
								<span class="craft-section-label">Produces</span>
								<div class="craft-output-display">
									<img class="craft-output-img" src="{{this.output.img}}" alt="{{this.output.name}}">
									<span class="craft-output-name">{{this.output.name}}</span>
									<span class="craft-output-qty">x{{this.output.quantity}}</span>
								</div>
							</div>
						</div>

						<button class="action-btn buy-btn craft-btn"
							data-action="craft"
							data-recipe-id="{{this.id}}"
							data-actor-id="{{../player.id}}"
							{{#unless this.can_craft}}disabled{{/unless}}>
							<i class="fas fa-hammer"></i> Craft
						</button>
					</div>
					{{/each}}
				</div>
				{{else}}
				<div class="empty-banner warning">
					<i class="fas fa-scroll"></i>
					<div class="banner-text">
						<h4>No Recipes Available</h4>
						<p>The Gamemaster has not configured any crafting recipes yet.</p>
					</div>
				</div>
				{{/if}}
			{{else}}
			<div class="empty-banner warning">
				<i class="fas fa-hammer"></i>
				<div class="banner-text">
					<h4>Crafting is Inactive</h4>
					<p>Wait for the Gamemaster to enable the crafting system.</p>
				</div>
			</div>
			{{/if}}

			<div class="history-section">
				<div class="section-title-row">
					<h3 class="section-heading">My Crafting History</h3>
				</div>
				<div class="logs-feed">
					{{#each player_craft_logs}}
					<div class="feed-item">
						<span class="item-time">{{this.formatted_time}}</span>
						<span class="item-text">
							Crafted <strong>{{this.output_name}}</strong> x{{this.output_qty}} via <strong>{{this.recipe_name}}</strong> ({{this.dt_cost}} {{#if (eq this.dt_cost 1)}}point{{else}}points{{/if}})
						</span>
					</div>
					{{else}}
					<div class="feed-empty">No crafting history yet.</div>
					{{/each}}
				</div>
			</div>

			{{else}}
			<div class="empty-banner danger">
				<i class="fas fa-user-slash"></i>
				<div class="banner-text">
					<h4>No Active Character</h4>
					<p>Please select or assign a controlled character token to access crafting.</p>
				</div>
			</div>
			{{/if}}
		</div>
		{{/if}}

		{{!-- ======================== PERKS TAB ======================== --}}
		{{#if tabs.perks.active}}
		<div class="tab actions-tab perks-tab">
			{{#if player.has_actor}}
			<div class="player-hero">
				<div class="hero-left">
					<span class="hero-subtitle">perk tree progression</span>
					<h2 class="hero-title">{{player.name}}</h2>
				</div>
				<div class="hero-points-card">
					<span class="points-val">{{player.points}}</span>
					<span class="points-lbl">Points</span>
				</div>
			</div>

			{{#if is_active}}
				{{#if player_trees.length}}
				<div class="perks-layout-container">
					<div class="perks-sidebar">
						<h4 class="sidebar-heading">My Perk Trees</h4>
						<div class="sidebar-tree-list">
							{{#each player_trees}}
							<button type="button" class="sidebar-tree-btn {{#if (eq this.id ../active_tree.id)}}active{{/if}}" data-action="select-player-tree" data-tree-id="{{this.id}}">
								<i class="fas fa-project-diagram"></i>
								<span>{{this.name}}</span>
							</button>
							{{/each}}
						</div>
					</div>

					<div class="perks-main-area">
						{{#if active_tree}}
						<div class="active-tree-header">
							<h3 class="active-tree-title">{{active_tree.name}}</h3>
						</div>

						<div class="tree-grid-display">
							{{#each active_tree.tiers}}
							<div class="tree-tier-row">
								<span class="tier-number-label">Tier {{this.tier_number}}</span>
								<div class="tier-nodes-row">
									{{#each this.nodes}}
									<div class="perk-node-card {{#if this.is_unlocked}}unlocked{{/if}} {{#if this.is_locked}}locked{{/if}} {{#if this.is_available}}available{{/if}}">
										<div class="node-main-content">
											<img class="node-icon" src="{{this.icon}}" alt="{{this.name}}">
											<div class="node-info">
												<h4 class="node-name">{{this.name}}</h4>
												<p class="node-desc">{{this.description}}</p>
												
												<div class="node-meta">
													{{#if this.requirements.length}}
													<span class="node-badge req-badge" title="Requires: {{this.req_list}}">
														<i class="fas fa-lock"></i> Requires: {{this.req_list}}
													</span>
													{{/if}}
													{{#if this.macro_name}}
													<span class="node-badge macro-badge"><i class="fas fa-terminal"></i> {{this.macro_name}}</span>
													{{/if}}
													{{#if this.effect}}
													<span class="node-badge effect-badge" title="Active Effect: {{this.effect.name}}"><i class="fas fa-magic"></i> Effect</span>
													{{/if}}
												</div>
											</div>
										</div>
										
										<div class="node-action-col">
											{{#if this.is_unlocked}}
											<span class="unlocked-status-badge"><i class="fas fa-check-circle"></i> Unlocked</span>
											{{#if ../../is_gm}}
											<div class="gm-node-actions">
												<button type="button" class="action-btn buy-btn refund-node-btn" 
													data-action="refund-node" 
													data-actor-id="{{../../player.id}}"
													data-tree-id="{{../../active_tree.id}}"
													data-node-id="{{this.id}}"
													title="Refund Perk (Locks node & refunds point cost)">
													Refund
												</button>
												<button type="button" class="action-btn buy-btn revoke-node-btn" 
													data-action="revoke-node" 
													data-actor-id="{{../../player.id}}"
													data-tree-id="{{../../active_tree.id}}"
													data-node-id="{{this.id}}"
													title="Revoke Perk (Locks node without refunding points)">
													Revoke
												</button>
											</div>
											{{/if}}
											{{/if}}
											{{#if this.is_locked}}
											<span class="locked-status-badge"><i class="fas fa-lock"></i> Locked</span>
											{{/if}}
											{{#if this.is_available}}
											<button type="button" class="action-btn buy-btn node-unlock-btn" 
												data-action="unlock-node" 
												data-actor-id="{{../../player.id}}"
												data-tree-id="{{../../active_tree.id}}"
												data-node-id="{{this.id}}"
												{{#unless this.can_afford}}disabled{{/unless}}>
												Unlock ({{this.cost}} {{#if (eq this.cost 1)}}point{{else}}points{{/if}})
											</button>
											{{/if}}
										</div>
									</div>
									{{/each}}
								</div>
							</div>
							{{/each}}
						</div>
						{{else}}
						<div class="empty-banner info">
							<i class="fas fa-project-diagram"></i>
							<div class="banner-text">
								<h4>Select a Perk Tree</h4>
								<p>Choose a perk tree from the sidebar to view your progress.</p>
							</div>
						</div>
						{{/if}}
					</div>
				</div>
				{{else}}
				<div class="empty-banner info">
					<i class="fas fa-project-diagram"></i>
					<div class="banner-text">
						<h4>No Perk Trees Assigned</h4>
						<p>You have not been assigned any perk trees by the Gamemaster.</p>
					</div>
				</div>
				{{/if}}
			{{else}}
			<div class="empty-banner warning">
				<i class="fas fa-hourglass-half"></i>
				<div class="banner-text">
					<h4>Downtime is currently inactive</h4>
					<p>Wait for the Gamemaster to activate downtime mode to view or progress in perk trees.</p>
				</div>
			</div>
			{{/if}}

			{{else}}
			<div class="empty-banner danger">
				<i class="fas fa-user-slash"></i>
				<div class="banner-text">
					<h4>No Active Character</h4>
					<p>Please select or assign a controlled character token to access perk trees.</p>
				</div>
			</div>
			{{/if}}
		</div>
		{{/if}}

		{{!-- ======================== MANAGE TAB ======================== --}}
		{{#if tabs.manage.active}}
		<div class="tab manage-tab">
			<div class="gm-top-panel">
				<div class="mode-toggle-group">
					<label class="ios-switch">
						<input type="checkbox" data-action="toggle-mode" {{#if is_active}}checked{{/if}}>
						<span class="switch-slider"></span>
					</label>
					<div class="toggle-info">
						<span class="toggle-title">Downtime Mode</span>
						<span class="toggle-desc">Toggle player access to downtime options</span>
					</div>
				</div>
				<button type="button" class="action-btn outline-btn logs-btn" data-action="open-logs">
					<i class="fas fa-history"></i> Logs
				</button>
			</div>

			<div class="gm-main-layout">
				<div class="layout-sidebar">
					<div class="section-title-row">
						<h3 class="section-heading">Characters</h3>
						<button type="button" class="map-filter-btn {{#if only_show_on_map}}active{{/if}}" data-action="toggle-map-filter" title="Only show on map">
							<i class="fas fa-map"></i>
						</button>
					</div>
					<div class="sidebar-search" style="margin-bottom: 10px;">
						<input type="text" id="yugen-downtime-actor-search" class="actor-search-input" placeholder="Search characters..." value="{{actor_search_query}}" style="background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; color: #ffffff; padding: 6px 10px; width: 100%; font-size: 0.8rem; box-sizing: border-box;">
					</div>
					<div class="actors-feed">
						{{#each actors}}
						<div class="actor-feed-item compact">
							<div class="actor-row-main">
								<img class="actor-avatar" src="{{this.img}}" alt="{{this.name}}">
								<div class="actor-details">
									<span class="actor-name">{{this.name}}</span>
									<span class="actor-points-label">{{this.points}} pts</span>
								</div>
								<button type="button" class="actor-edit-btn" data-action="edit-actor" data-actor-id="{{this.id}}" title="Edit Character Downtime Settings">
									<i class="fas fa-edit"></i>
								</button>
							</div>
						</div>
						{{else}}
						<div class="feed-empty">No character actors found.</div>
						{{/each}}
					</div>
				</div>

				<div class="layout-content">
					{{!-- Sub-tabs for Actions and Recipes --}}
					<div class="gm-sub-tabs">
						<button type="button" class="sub-tab-item {{#if (eq sub_tab "actions-config")}}active{{/if}}" data-action="sub-tab" data-tab="actions-config">
							<i class="fas fa-tasks"></i> Downtime Actions
						</button>
						<button type="button" class="sub-tab-item {{#if (eq sub_tab "recipes-config")}}active{{/if}}" data-action="sub-tab" data-tab="recipes-config">
							<i class="fas fa-hammer"></i> Craft Recipes
						</button>
						<button type="button" class="sub-tab-item {{#if (eq sub_tab "perks-config")}}active{{/if}}" data-action="sub-tab" data-tab="perks-config">
							<i class="fas fa-project-diagram"></i> Perk Trees
						</button>
					</div>

					{{#if (eq sub_tab "actions-config")}}
					<div class="sub-tab-content active">
						<div class="section-title-row">
							<h3 class="section-heading">Downtime Configurations</h3>
							<button type="button" class="action-btn outline-btn compact-btn" data-action="add-action">
								<i class="fas fa-plus"></i> New Action
							</button>
						</div>

						<div class="config-list">
							{{#each actions}}
							<div class="config-row-item" data-action-id="{{this.id}}">
								<div class="config-row-main">
									<span class="config-row-name">{{this.name}}</span>
									<div class="config-row-badges">
										<span class="row-badge cost-badge">{{this.cost}} {{#if (eq this.cost 1)}}point{{else}}points{{/if}}</span>
										{{#if this.roll_check}}
										<span class="row-badge check-badge"><i class="fas fa-dice-d20"></i> {{this.roll_check}} {{#if this.dc}}(DC {{this.dc}}){{/if}}</span>
										{{/if}}
										{{#if this.macro_name}}
										<span class="row-badge macro-badge"><i class="fas fa-terminal"></i> {{this.macro_name}}</span>
										{{/if}}
									</div>
								</div>
								<div class="config-row-actions">
									<button type="button" class="config-row-btn edit-btn" data-action="edit-action" data-action-id="{{this.id}}" title="Edit Action">
										<i class="fas fa-edit"></i>
									</button>
									<button type="button" class="config-row-btn delete-btn" data-action="delete-action" data-action-id="{{this.id}}" title="Delete Action">
										<i class="fas fa-trash-alt"></i>
									</button>
								</div>
							</div>
							{{else}}
							<div class="feed-empty">No downtime actions configured yet. Click <strong>New Action</strong> to create one.</div>
							{{/each}}
						</div>
					</div>
					{{/if}}

					{{#if (eq sub_tab "recipes-config")}}
					<div class="sub-tab-content active">
						<div class="section-title-row">
							<h3 class="section-heading">Craft Recipes</h3>
							<button type="button" class="action-btn outline-btn compact-btn" data-action="add-recipe">
								<i class="fas fa-plus"></i> New Recipe
							</button>
						</div>

						<div class="config-list">
							{{#each recipes}}
							<div class="config-row-item" data-recipe-id="{{this.id}}">
								<div class="config-row-main">
									<span class="config-row-name">{{this.name}}</span>
									<div class="config-row-badges">
										<span class="row-badge cost-badge">{{this.dt_cost}} {{#if (eq this.dt_cost 1)}}point{{else}}points{{/if}}</span>
										{{#if this.output.uuid}}
										<span class="row-badge output-badge">Produces: {{this.output.name}} (x{{this.output.quantity}})</span>
										{{/if}}
										<span class="row-badge ingredients-count-badge">Ingredients: {{this.ingredients.length}}</span>
									</div>
								</div>
								<div class="config-row-actions">
									<button type="button" class="config-row-btn edit-btn" data-action="edit-recipe" data-recipe-id="{{this.id}}" title="Edit Recipe">
										<i class="fas fa-edit"></i>
									</button>
									<button type="button" class="config-row-btn delete-btn" data-action="delete-recipe" data-recipe-id="{{this.id}}" title="Delete Recipe">
										<i class="fas fa-trash-alt"></i>
									</button>
								</div>
							</div>
							{{else}}
							<div class="feed-empty">No recipes configured yet. Click <strong>New Recipe</strong> to create one.</div>
							{{/each}}
						</div>
					</div>
					{{/if}}

					{{#if (eq sub_tab "perks-config")}}
					<div class="sub-tab-content active">
						<div class="section-title-row">
							<h3 class="section-heading">Perk Trees</h3>
							<button type="button" class="action-btn outline-btn compact-btn" data-action="add-tree">
								<i class="fas fa-plus"></i> New Tree
							</button>
						</div>

						<div class="config-list">
							{{#each perk_trees}}
							<div class="config-row-item" data-tree-id="{{this.id}}">
								<div class="config-row-main">
									<span class="config-row-name">{{this.name}}</span>
									<div class="config-row-badges">
										<span class="row-badge perk-nodes-count-badge">Perks: {{this.nodes.length}}</span>
									</div>
								</div>
								<div class="config-row-actions">
									<button type="button" class="config-row-btn edit-btn" data-action="edit-tree" data-tree-id="{{this.id}}" title="Edit Perk Tree">
										<i class="fas fa-edit"></i>
									</button>
									<button type="button" class="config-row-btn delete-btn" data-action="delete-tree" data-tree-id="{{this.id}}" title="Delete Perk Tree">
										<i class="fas fa-trash-alt"></i>
									</button>
								</div>
							</div>
							{{else}}
							<div class="feed-empty">No perk trees configured yet. Click <strong>New Tree</strong> to create one.</div>
							{{/each}}
						</div>
					</div>
					{{/if}}
				</div>
			</div>
		</div>
		{{/if}}

	</section>
</div>
